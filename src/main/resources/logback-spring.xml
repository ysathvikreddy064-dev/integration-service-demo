<configuration>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                {"ts":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%p","app":"${APP_NAME}",
                "correlationId":"%X{correlationId}","logger":"%logger{36}","msg":"%m"}%n
            </pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
